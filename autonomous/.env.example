# autonomous/.env — copy to `.env` and fill in. NEVER committed (.gitignore),
# NEVER readable by the agent (deny rules block all .env reads).
#
# Reuse the bot you made for WS4 (@BotFather → /newbot → token).
TELEGRAM_BOT_TOKEN=
# Your OWN chat id — pins the push to you (a self-notification, no HITL needed).
# Find it: message your bot once, then open
#   https://api.telegram.org/bot<TOKEN>/getUpdates  → result[0].message.chat.id
TELEGRAM_CHAT_ID=
